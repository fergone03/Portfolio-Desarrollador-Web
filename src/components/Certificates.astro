---

<div class="cert-grid">
  {CERTIFICATES.map((cert) => (
    <div class="cert-card spotlight glass">
      <div class="cert-header">
        <span class="cert-date">{cert.date}</span>
        <span class="cert-issuer">{cert.issuer}</span>
      </div>
      <p class="cert-title">{cert.title}</p>
      <div class="cert-tags">
        {cert.tags.map((tag) => (
          <span class="cert-tag" style={`color:${tag.color};`}>
            <tag.icon class="cert-tag-icon" />
            {tag.name}
          </span>
        ))}
      </div>
    </div>
  ))}
</div>

<style>
  .cert-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 10px;
  }

  .cert-card {
    border-radius: 12px;
    padding: 1rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.2s cubic-bezier(0.16,1,0.3,1), border-color 0.2s;
  }
  .cert-card:hover {
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--accent) 25%, var(--border));
  }

  .cert-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .cert-date {
    font-family: "Courier New", monospace;
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    font-weight: 600;
  }

  .cert-issuer {
    font-size: 0.6rem;
    font-weight: 600;
    color: var(--accent-2);
    letter-spacing: 0.03em;
  }

  .cert-title {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--text);
    line-height: 1.35;
  }

  .cert-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 2px;
  }

  .cert-tag {
    display: inline-flex;
    align-items: center;
    gap: 3px;
    font-size: 0.65rem;
    font-weight: 500;
    opacity: 0.8;
  }

  .cert-tag-icon {
    width: 11px;
    height: 11px;
    flex-shrink: 0;
  }
</style>
