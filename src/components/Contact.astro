---
import GitHubIcon from "../assets/media/icons/GitHubIcon.astro";
import LinkedInIcon from "../assets/media/icons/LinkedInIcon.astro";
import MailIcon from "../assets/media/icons/MailIcon.astro";
---

<div class="contact-wrap">
  <!-- Left: typography -->
  <div class="contact-left">
    <p class="contact-label">// Contacto</p>
    <h2 class="contact-heading" data-i18n="c.title">¿Hablamos?</h2>
    <p class="contact-desc" data-i18n="c.desc">
      Estoy abierto a nuevas oportunidades, colaboraciones o simplemente a charlar sobre tecnología y datos.
    </p>
  </div>

  <!-- Right: links -->
  <div class="contact-links">
    <a href="mailto:fergonesteban03@gmail.com" class="contact-btn contact-btn-primary">
      <MailIcon class="size-4" />
      fergonesteban03@gmail.com
    </a>
    <a href="https://www.linkedin.com/in/estebanfernandezgonzalez/" target="_blank" rel="noopener" class="contact-btn">
      <LinkedInIcon class="size-4" />
      LinkedIn
    </a>
    <a href="https://github.com/fergone03" target="_blank" rel="noopener" class="contact-btn">
      <GitHubIcon class="size-4" />
      GitHub
    </a>
  </div>
</div>

<style>
  .contact-wrap {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding: 3rem 0 1rem;
    border-top: 1px solid var(--border);
  }
  @media (min-width: 768px) {
    .contact-wrap {
      grid-template-columns: 1fr auto;
      align-items: end;
      gap: 4rem;
    }
  }

  .contact-label {
    font-family: "Courier New", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 0.75rem;
  }

  .contact-heading {
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    line-height: 0.95;
    color: var(--text);
    margin-bottom: 1.25rem;
  }

  .contact-desc {
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-2);
    max-width: 40ch;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    flex-shrink: 0;
  }

  .contact-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.625rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 0.7rem 1.2rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-2);
    transition: background 0.2s, color 0.2s, transform 0.15s, border-color 0.2s;
    white-space: nowrap;
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
  }
  .contact-btn:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--border) 60%, var(--accent));
    background: color-mix(in srgb, var(--surface) 50%, var(--border));
    transform: translateX(4px);
  }
  .contact-btn:active { transform: translateX(2px) translateY(1px); }

  .contact-btn-primary {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
  }
  .contact-btn-primary:hover {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--accent) 55%, transparent);
    color: var(--accent);
  }
</style>
