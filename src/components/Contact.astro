---
import GitHubIcon from "../assets/media/icons/GitHubIcon.astro";
import LinkedInIcon from "../assets/media/icons/LinkedInIcon.astro";
import MailIcon from "../assets/media/icons/MailIcon.astro";
---

<div class="spotlight glass rounded-2xl p-8 sm:p-14 text-center" style="border-radius:20px;">
  <div class="mx-auto mb-5 flex size-16 items-center justify-center rounded-full"
       style="background:color-mix(in srgb,var(--accent) 12%,transparent); border:1px solid color-mix(in srgb,var(--accent) 30%,transparent);">
    <span class="text-2xl">👋</span>
  </div>

  <h2 class="text-3xl sm:text-4xl font-bold mb-3" style="color:var(--text);"
      data-i18n="c.title">¿Hablamos?</h2>

  <p class="max-w-md mx-auto mb-8 text-base" style="color:var(--text-2);"
     data-i18n="c.desc">
    Estoy abierto a nuevas oportunidades, colaboraciones o simplemente a charlar sobre tecnología y datos.
  </p>

  <div class="flex flex-col sm:flex-row gap-3 justify-center">
    <a href="mailto:fergonesteban03@gmail.com"
       class="contact-btn contact-btn-accent">
      <MailIcon class="size-4" />
      fergonesteban03@gmail.com
    </a>
    <a href="https://www.linkedin.com/in/estebanfernandezgonzalez/" target="_blank" rel="noopener"
       class="contact-btn">
      <LinkedInIcon class="size-4" style="color:var(--accent-2);" />
      LinkedIn
    </a>
    <a href="https://github.com/fergone03" target="_blank" rel="noopener"
       class="contact-btn">
      <GitHubIcon class="size-4" />
      GitHub
    </a>
  </div>
</div>

<style>
  .contact-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.625rem;
    border-radius: 12px;
    border: 1px solid var(--border);
    background: var(--surface);
    padding: 0.75rem 1.25rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-2);
    transition: background 0.2s, color 0.2s, transform 0.2s;
    width: 100%;
  }
  @media (min-width: 640px) { .contact-btn { width: auto; } }
  .contact-btn:hover {
    color: var(--text);
    background: color-mix(in srgb, var(--surface) 50%, var(--border));
    transform: translateY(-2px);
  }
  .contact-btn-accent {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 10%, transparent);
  }
  .contact-btn-accent:hover {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    color: var(--accent);
  }
</style>
