---
interface Props {
  title?: string;
  company?: string;
  description?: string;
  date?: string;
  index?: number;
}

const { title, company, date, description, index } = Astro.props;
const i = index ?? 0;
---

<li class="relative pl-6 pb-8 group">
  <span class="absolute left-0 top-2.5 bottom-0 w-px" style="background:var(--border);"></span>
  <span class="absolute left-[-4px] top-2.5 size-2.5 rounded-full ring-4"
        style="background:var(--accent); ring-color:var(--bg);"></span>

  <div class="spotlight glass rounded-xl p-5 transition duration-300 group-hover:border-opacity-30"
       style="border-radius:12px;">
    <time class="text-xs font-mono tracking-wide uppercase" style="color:var(--accent);"
          data-i18n={`e${i}.date`}>{date}</time>

    <h3 class="mt-1 text-base font-semibold" style="color:var(--text);"
        data-i18n={`e${i}.title`}>{title}</h3>

    {company && (
      <p class="text-xs font-medium mt-0.5 mb-3" style="color:var(--accent-2);"
         data-i18n={`e${i}.co`}>{company}</p>
    )}

    <p class="text-sm leading-relaxed" style="color:var(--text-2);"
       data-i18n={`e${i}.desc`}>{description}</p>
  </div>
</li>
