---
// Self-contained CV page — no Layout dependency so print/PDF stays clean
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>CV — Esteban Fernández | Full Stack Developer & Data Engineer</title>
  <meta name="description" content="Curriculum Vitae de Esteban Fernández González, Full Stack Developer y Data Engineer con base en Granada, España." />
  <meta name="robots" content="noindex" />
  <link rel="icon" type="image/svg+xml" href="/code.svg" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    /* ─── Reset ──────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    a { color: inherit; text-decoration: none; }

    /* ─── Tokens ─────────────────────────────────────────── */
    :root {
      --accent:   #7C3AED;
      --text:     #0F172A;
      --text-2:   #374151;
      --text-3:   #64748B;
      --border:   #E2E8F0;
      --bg-page:  #F1F5F9;
      --bg-card:  #FFFFFF;
    }

    /* ─── Base ───────────────────────────────────────────── */
    body {
      font-family: 'Inter', system-ui, -apple-system, sans-serif;
      background: var(--bg-page);
      color: var(--text);
      font-size: 13.5px;
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
    }

    /* ─── Controls bar ───────────────────────────────────── */
    .controls {
      position: sticky;
      top: 0;
      z-index: 50;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 12px;
      padding: 10px 24px;
      background: rgba(255,255,255,0.90);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--border);
      box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .btn-back {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 12.5px;
      font-weight: 500;
      color: var(--text-2);
      transition: color 0.18s;
    }
    .btn-back:hover { color: var(--accent); }
    .controls-right { display: flex; align-items: center; gap: 10px; }
    .controls-hint {
      font-size: 11.5px;
      color: var(--text-3);
      font-family: 'JetBrains Mono', monospace;
    }
    .btn-pdf {
      display: inline-flex;
      align-items: center;
      gap: 7px;
      background: var(--accent);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 7px 18px;
      font-size: 12.5px;
      font-weight: 600;
      font-family: inherit;
      cursor: pointer;
      transition: opacity 0.2s, transform 0.15s;
    }
    .btn-pdf:hover { opacity: 0.88; transform: translateY(-1px); }

    /* ─── Page wrapper ───────────────────────────────────── */
    .page-wrap {
      max-width: 880px;
      margin: 36px auto 72px;
      padding: 0 20px;
    }

    /* ─── CV card ────────────────────────────────────────── */
    .cv {
      background: var(--bg-card);
      border-radius: 12px;
      box-shadow: 0 2px 8px rgba(0,0,0,0.06), 0 12px 40px rgba(0,0,0,0.07);
      overflow: hidden;
    }

    /* ─── Header ─────────────────────────────────────────── */
    .cv-header {
      padding: 36px 52px 28px;
      border-left: 5px solid var(--accent);
      background: linear-gradient(135deg, #FAFBFF 0%, #F5F0FF 100%);
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: flex-start;
      gap: 28px;
    }
    .cv-photo {
      width: 88px;
      height: 88px;
      border-radius: 50%;
      object-fit: cover;
      object-position: top center;
      flex-shrink: 0;
      border: 3px solid var(--accent);
      box-shadow: 0 2px 12px rgba(124,58,237,0.18);
    }
    .cv-header-text { flex: 1; min-width: 0; }
    .cv-name {
      font-size: 2.2rem;
      font-weight: 700;
      color: var(--text);
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin-bottom: 4px;
    }
    .cv-title {
      font-size: 0.88rem;
      font-weight: 600;
      color: var(--accent);
      letter-spacing: 0.04em;
      margin-bottom: 16px;
      font-family: 'JetBrains Mono', monospace;
    }
    .cv-contact {
      display: flex;
      flex-wrap: wrap;
      gap: 5px 18px;
      font-size: 11.5px;
      color: var(--text-2);
    }
    .cv-contact-item {
      display: inline-flex;
      align-items: center;
      gap: 5px;
    }
    .cv-contact-item svg {
      width: 11px;
      height: 11px;
      flex-shrink: 0;
      color: var(--accent);
    }
    .cv-contact a:hover { color: var(--accent); }

    /* ─── Body ───────────────────────────────────────────── */
    .cv-body { padding: 32px 52px 40px; }

    /* ─── Section ────────────────────────────────────────── */
    .cv-section { margin-bottom: 26px; }
    .cv-section:last-child { margin-bottom: 0; }

    .section-label {
      font-size: 9px;
      font-weight: 700;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      font-family: 'JetBrains Mono', monospace;
      margin-bottom: 10px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--border);
    }

    /* ─── Summary ────────────────────────────────────────── */
    .summary-text { color: var(--text-2); line-height: 1.7; }

    /* ─── Skills ─────────────────────────────────────────── */
    .skills-list { display: flex; flex-direction: column; gap: 6px; }
    .skill-row { display: flex; gap: 10px; align-items: baseline; }
    .skill-cat {
      font-weight: 600;
      font-size: 12.5px;
      color: var(--text);
      min-width: 118px;
      flex-shrink: 0;
    }
    .skill-values { font-size: 13px; color: var(--text-2); line-height: 1.5; }

    /* ─── Experience ─────────────────────────────────────── */
    .exp-list { display: flex; flex-direction: column; gap: 18px; }
    .exp-top {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      gap: 12px;
      margin-bottom: 1px;
    }
    .exp-role { font-weight: 700; font-size: 13.5px; color: var(--text); }
    .exp-date {
      font-size: 11px;
      color: var(--text-3);
      white-space: nowrap;
      flex-shrink: 0;
      font-family: 'JetBrains Mono', monospace;
      margin-top: 2px;
    }
    .exp-company {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
      margin-bottom: 6px;
    }
    .exp-bullets { list-style: none; display: flex; flex-direction: column; gap: 3px; }
    .exp-bullets li {
      font-size: 13px;
      color: var(--text-2);
      padding-left: 14px;
      position: relative;
      line-height: 1.55;
    }
    .exp-bullets li::before {
      content: '▸';
      position: absolute;
      left: 0;
      color: var(--accent);
      font-size: 8px;
      top: 4px;
    }

    /* ─── Projects ───────────────────────────────────────── */
    .proj-list { display: flex; flex-direction: column; gap: 11px; }
    .proj-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 1px;
    }
    .proj-name { font-weight: 600; font-size: 13px; color: var(--text); }
    .proj-stack {
      font-size: 10.5px;
      color: var(--text-3);
      font-family: 'JetBrains Mono', monospace;
      white-space: nowrap;
      flex-shrink: 0;
    }
    .proj-desc { font-size: 13px; color: var(--text-2); line-height: 1.5; }
    .proj-tfg {
      font-size: 10px;
      font-weight: 700;
      color: var(--accent);
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      border: 1px solid color-mix(in srgb, var(--accent) 30%, transparent);
      border-radius: 4px;
      padding: 1px 5px;
      vertical-align: middle;
      font-family: 'JetBrains Mono', monospace;
      letter-spacing: 0.05em;
    }

    /* ─── Education ──────────────────────────────────────── */
    .edu-list { display: flex; flex-direction: column; gap: 11px; }
    .edu-top {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 1px;
    }
    .edu-degree { font-weight: 600; font-size: 13px; color: var(--text); }
    .edu-year {
      font-size: 11px;
      color: var(--text-3);
      font-family: 'JetBrains Mono', monospace;
      flex-shrink: 0;
    }
    .edu-school { font-size: 12px; color: var(--accent); font-weight: 500; }
    .edu-note { font-size: 12px; color: var(--text-2); margin-top: 2px; }

    /* ─── Languages ──────────────────────────────────────── */
    .lang-row { display: flex; gap: 24px; flex-wrap: wrap; }
    .lang-item { display: flex; gap: 7px; align-items: center; }
    .lang-name { font-weight: 600; font-size: 13px; }
    .lang-level { font-size: 13px; color: var(--text-2); }

    /* ─── Wrapper for edu + lang side-by-side in print ───── */
    .edu-lang-wrap { display: contents; }

    /* ─── Print ──────────────────────────────────────────── */
    @media print {
      @page { size: A4; margin: 8mm 11mm; }

      html, body {
        font-size: 10.5px;
        line-height: 1.38;
        background: #fff !important;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }

      .controls { display: none !important; }

      .page-wrap { margin: 0; padding: 0; max-width: 100%; }
      .cv { box-shadow: none; border-radius: 0; }

      /* Header */
      .cv-header { padding: 13px 22px 11px; gap: 16px; }
      .cv-photo  { width: 64px; height: 64px; border-width: 2px; }
      .cv-name   { font-size: 21px; margin-bottom: 2px; }
      .cv-title  { font-size: 10px; margin-bottom: 9px; }
      .cv-contact { gap: 2px 13px; font-size: 10px; }
      .cv-contact-item svg { width: 10px; height: 10px; }

      /* Body */
      .cv-body { padding: 10px 22px 10px; }
      .cv-section { margin-bottom: 9px; }
      .section-label { font-size: 7.5px; margin-bottom: 4px; padding-bottom: 3px; }

      /* Summary — 2 lines max */
      .summary-text { font-size: 10.5px; line-height: 1.38; }

      /* Skills → 2-column grid */
      .skills-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3px 18px;
      }
      .skill-row:last-child { grid-column: 1 / -1; }
      .skill-cat   { min-width: 74px; font-size: 10.5px; }
      .skill-values { font-size: 10.5px; line-height: 1.38; }

      /* Experience */
      .exp-list   { gap: 7px; }
      .exp-role   { font-size: 11px; }
      .exp-company { font-size: 10px; margin-bottom: 3px; }
      .exp-date   { font-size: 9.5px; }
      .exp-bullets { gap: 1px; }
      .exp-bullets li { font-size: 10.5px; line-height: 1.35; padding-left: 11px; }
      .exp-bullets li::before { top: 3px; }

      /* Projects → 2-column grid */
      .proj-list {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4px 18px;
      }
      .proj-name  { font-size: 10.5px; }
      .proj-stack { font-size: 9px; }
      .proj-desc  { font-size: 10px; line-height: 1.32; }
      .proj-tfg   { font-size: 8.5px; padding: 0 3px; }

      /* Education + Languages → side by side */
      .edu-lang-wrap {
        display: grid;
        grid-template-columns: 3fr 1fr;
        gap: 0 20px;
        align-items: start;
      }
      .edu-lang-wrap .cv-section { margin-bottom: 0; }
      .edu-list   { gap: 5px; }
      .edu-degree { font-size: 10.5px; }
      .edu-year   { font-size: 9.5px; }
      .edu-school { font-size: 10px; }
      .edu-note   { display: none; }

      .lang-row { gap: 12px; flex-direction: column; }
      .lang-name  { font-size: 10.5px; }
      .lang-level { font-size: 10px; }
    }

    /* ─── Responsive ─────────────────────────────────────── */
    @media (max-width: 640px) {
      .cv-header { padding: 24px 22px 20px; border-left-width: 4px; }
      .cv-body   { padding: 22px 22px 28px; }
      .cv-name   { font-size: 1.7rem; }
      .exp-top, .proj-top, .edu-top { flex-direction: column; gap: 2px; }
      .skill-cat { min-width: 90px; }
      .controls-hint { display: none; }
    }
  </style>
</head>

