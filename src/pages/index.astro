---
import Layout from "../layouts/Layout.astro";
import Badge from "../components/Badge.astro";
import SectionContainer from "../components/SectionContainer.astro";
import GitHubIcon from "../assets/media/icons/GitHubIcon.astro";
import LinkedInIcon from "../assets/media/icons/LinkedInIcon.astro";
import MailIcon from "../assets/media/icons/MailIcon.astro";
import DownloadIcon from "../assets/media/icons/DownloadIcon.astro";
import Experience from "../components/Experience.astro";
import Projects from "../components/Projects.astro";
import Contact from "../components/Contact.astro";
import SobreMi from "../components/SobreMi.astro";
import Skills from "../components/Skills.astro";
import Certificates from "../components/Certificates.astro";
---

<Layout
  title="Dev Esteban | Full Stack Developer & Data Engineer"
  description="Portfolio de Esteban Fernández, Full Stack Developer y Data Engineer con base en Granada, España."
>
  <main>

    <!-- ══ HERO ══ -->
    <SectionContainer id="top">
      <div class="hero-grid">

        <!-- LEFT: content -->
        <div class="hero-left">

          <div class="hero-eyebrow animate-fade-in">
            <span class="hero-location">Granada, España</span>
            <span class="hero-dot" aria-hidden="true"></span>
            <a href="https://www.linkedin.com/in/estebanfernandezgonzalez/" target="_blank" rel="noopener">
              <Badge>Disponible para trabajar</Badge>
            </a>
          </div>

          <div class="hero-name-block animate-fade-up animate-delay-100">
            <h1>
              <span class="hero-name">Esteban</span>
              <span class="hero-surname">Fernández</span>
            </h1>
          </div>

          <p class="hero-role animate-fade-up animate-delay-150">
            Full Stack Developer <span class="hero-sep">&amp;</span> Data Engineer
          </p>

          <p class="hero-desc animate-fade-up animate-delay-200" data-i18n="hero.desc">
            <strong>Full Stack Developer &amp; Data Engineer</strong> con base en Granada, España.
            Apasionado por crear soluciones innovadoras y transformar datos en decisiones.
          </p>

          <nav class="hero-nav animate-fade-up animate-delay-300">
            <div class="hero-social">
              <a href="https://github.com/fergone03" target="_blank" rel="noopener" class="social-link" aria-label="GitHub">
                <GitHubIcon class="size-5" />
              </a>
              <a href="https://www.linkedin.com/in/estebanfernandezgonzalez/" target="_blank" rel="noopener" class="social-link" aria-label="LinkedIn">
                <LinkedInIcon class="size-5" />
              </a>
              <a href="mailto:fergonesteban03@gmail.com" class="social-link" aria-label="Email">
                <MailIcon class="size-5" />
              </a>
            </div>
            <a href="/files/CV_New_Esteban.pdf" target="_blank" class="cv-cta">
              <DownloadIcon class="size-4" />
              <span data-i18n="hero.cv">Descargar CV</span>
            </a>
          </nav>
        </div>

        <!-- RIGHT: terminal visual -->
        <div class="hero-right animate-fade-in animate-delay-400" aria-hidden="true">
          <div class="terminal">
            <!-- Traffic lights bar -->
            <div class="terminal-bar">
              <span class="t-dot t-red"></span>
              <span class="t-dot t-yellow"></span>
              <span class="t-dot t-green"></span>
              <span class="t-path">~/esteban/portfolio</span>
            </div>
            <!-- Terminal body -->
            <div class="terminal-body">
              <div class="t-line t-d1"><span class="t-prompt">→</span> <span class="t-cmd">whoami</span></div>
              <div class="t-line t-out t-d2">Esteban Fernández, Granada</div>
              <div class="t-line t-d3"><span class="t-prompt">→</span> <span class="t-cmd">cat status.txt</span></div>
              <div class="t-line t-out t-available t-d4">✓ Available for work</div>
              <div class="t-line t-d5"><span class="t-prompt">→</span> <span class="t-cmd">ls skills/</span></div>
              <div class="t-line t-out t-d6">fullstack/&nbsp;&nbsp;data-eng/&nbsp;&nbsp;devops/</div>
              <div class="t-line t-d7"><span class="t-prompt">→</span> <span class="t-cursor">▋</span></div>
            </div>
          </div>

          <!-- Floating stat pills -->
          <div class="t-stat t-stat-a">
            <span class="t-num">6+</span>
            <span class="t-lbl">proyectos</span>
          </div>
          <div class="t-stat t-stat-b">
            <span class="t-num">3+</span>
            <span class="t-lbl">años exp.</span>
          </div>
        </div>

      </div>
    </SectionContainer>

    <!-- ══ SOBRE MÍ ══ -->
    <SectionContainer id="sobre-mi">
      <div data-animate>
        <h2 class="section-title" data-i18n="title.about">Sobre mí</h2>
        <SobreMi />
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/files/CV_New_Esteban.pdf" target="_blank" class="pill-btn">
            <DownloadIcon class="size-4" />
            <span data-i18n="about.cv">Descargar CV</span>
          </a>
        </div>
      </div>
    </SectionContainer>

    <!-- ══ HABILIDADES ══ -->
    <SectionContainer id="skills">
      <div data-animate>
        <h2 class="section-title" data-i18n="title.skills">Stack técnico</h2>
        <Skills />
      </div>
    </SectionContainer>

    <!-- ══ PROYECTOS ══ -->
    <SectionContainer id="proyectos">
      <div data-animate>
        <div class="section-title-row">
          <h2 class="section-title" data-i18n="title.projects">Proyectos</h2>
          <a href="https://github.com/fergone03" target="_blank" rel="noopener" class="github-more">
            <GitHubIcon class="size-4" />
            <span data-i18n="projects.more">más en GitHub</span>
          </a>
        </div>
        <Projects />
      </div>
    </SectionContainer>

    <!-- ══ CERTIFICACIONES ══ -->
    <SectionContainer id="certificaciones">
      <div data-animate>
        <h2 class="section-title" data-i18n="title.certs">Certificaciones</h2>
        <Certificates />
      </div>
    </SectionContainer>

    <!-- ══ EXPERIENCIA ══ -->
    <SectionContainer id="experiencia">
      <div data-animate>
        <h2 class="section-title" data-i18n="title.experience">Experiencia laboral</h2>
        <Experience />
      </div>
    </SectionContainer>

    <!-- ══ CONTACTO ══ -->
    <SectionContainer id="contacto">
      <div data-animate>
        <Contact />
      </div>
    </SectionContainer>

  </main>
</Layout>

<style>
  /* ── Section title row ── */
  .section-title-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0;
  }
  .section-title-row .section-title { margin-bottom: 0; }

  .github-more {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--text-3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 0.3rem 0.7rem;
    transition: color 0.2s, border-color 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .github-more:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--border) 60%, var(--text));
    transform: translateY(-1px);
  }

  /* ── Hero grid ── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
    align-items: center;
    min-height: 100dvh;
    padding: 6rem 0 4rem;
  }
  @media (min-width: 1024px) {
    .hero-grid {
      grid-template-columns: 1fr 400px;
      gap: 4rem;
      padding: 2rem 0;
    }
  }

  /* ── Hero left ── */
  .hero-left { display: flex; flex-direction: column; gap: 0; }

  .hero-eyebrow {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0;
  }
  .hero-location {
    font-family: "Courier New", monospace;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-3);
  }
  .hero-dot {
    width: 3px;
    height: 3px;
    border-radius: 50%;
    background: var(--text-3);
    flex-shrink: 0;
  }

  .hero-name-block { margin-top: 1.25rem; margin-bottom: 0; }

  .hero-name {
    display: block;
    font-size: clamp(3.8rem, 9vw, 6.5rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 0.9;
    color: var(--text);
  }

  .hero-surname {
    display: block;
    font-size: clamp(2rem, 5vw, 3.6rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: var(--text-2);
    margin-bottom: 0.75rem;
  }

  .hero-role {
    font-family: "Courier New", monospace;
    font-size: 0.75rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--accent);
    margin-top: 0.5rem;
    margin-bottom: 0;
  }

  .hero-sep { color: var(--accent-2); margin: 0 0.3em; }

  .hero-desc {
    margin-top: 1.5rem;
    max-width: 46ch;
    font-size: 0.95rem;
    line-height: 1.7;
    color: var(--text-2);
  }
  .hero-desc strong { color: var(--text); font-weight: 500; }

  .hero-nav {
    margin-top: 2rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
  }

  /* ── Pill buttons ── */
  .pill-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);
    padding: 0.55rem 1rem;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-2);
    transition: background 0.2s, color 0.2s, transform 0.15s, border-color 0.2s;
  }
  .pill-btn:hover {
    background: color-mix(in srgb, var(--surface) 50%, var(--border));
    color: var(--text);
    border-color: color-mix(in srgb, var(--border) 60%, var(--text));
    transform: translateY(-2px);
  }
  .pill-btn:active { transform: translateY(0); }
  .pill-accent {
    border-color: color-mix(in srgb, var(--accent) 45%, transparent);
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 9%, transparent);
  }
  .pill-accent:hover {
    background: color-mix(in srgb, var(--accent) 18%, transparent);
    border-color: color-mix(in srgb, var(--accent) 60%, transparent);
    color: var(--accent);
  }

  /* ── Social + CTA row ── */
  .hero-social {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-3);
    transition: color 0.2s, border-color 0.2s, background 0.2s, transform 0.15s;
  }
  .social-link:hover {
    color: var(--text);
    border-color: color-mix(in srgb, var(--border) 60%, var(--text));
    background: color-mix(in srgb, var(--surface) 50%, var(--border));
    transform: translateY(-2px);
  }
  .social-link:active { transform: translateY(0); }

  .cv-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    border-radius: 8px;
    border: 1px solid color-mix(in srgb, var(--accent) 40%, transparent);
    background: color-mix(in srgb, var(--accent) 8%, transparent);
    padding: 0.5rem 1rem;
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--accent);
    letter-spacing: 0.02em;
    transition: background 0.2s, border-color 0.2s, transform 0.15s;
  }
  .cv-cta:hover {
    background: color-mix(in srgb, var(--accent) 16%, transparent);
    border-color: color-mix(in srgb, var(--accent) 65%, transparent);
    transform: translateY(-2px);
  }
  .cv-cta:active { transform: translateY(0); }

  /* ── Hero right: terminal ── */
  .hero-right {
    position: relative;
    display: none;
  }
  @media (min-width: 1024px) {
    .hero-right { display: block; }
  }

  .terminal {
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 24px 60px rgba(0,0,0,0.15);
    backdrop-filter: blur(14px);
    border-radius: 14px;
    overflow: hidden;
    font-family: "JetBrains Mono", "Courier New", monospace;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 14px;
    border-bottom: 1px solid var(--border);
    background: color-mix(in srgb, var(--surface) 60%, transparent);
  }
  .t-dot {
    width: 10px; height: 10px;
    border-radius: 50%;
    flex-shrink: 0;
  }
  .t-red    { background: #FF5F56; }
  .t-yellow { background: #FFBD2E; }
  .t-green  { background: #27C93F; }
  .t-path {
    margin-left: 6px;
    font-size: 11px;
    color: var(--text-3);
    letter-spacing: 0.02em;
  }

  .terminal-body {
    padding: 18px 20px 22px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .t-line {
    font-size: 12.5px;
    line-height: 1.7;
    opacity: 0;
    animation: fadeIn 0.35s ease forwards;
    color: var(--text-2);
  }
  .t-d1 { animation-delay: 0.4s; }
  .t-d2 { animation-delay: 0.9s; }
  .t-d3 { animation-delay: 1.4s; }
  .t-d4 { animation-delay: 1.9s; }
  .t-d5 { animation-delay: 2.3s; }
  .t-d6 { animation-delay: 2.8s; }
  .t-d7 { animation-delay: 3.2s; }

  .t-prompt { color: var(--accent); margin-right: 6px; }
  .t-cmd    { color: var(--text); }
  .t-out    { padding-left: 18px; }
  .t-available { color: #4ade80; }

  .t-cursor {
    color: var(--accent);
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink { 0%,100%{opacity:1} 50%{opacity:0} }

  /* ── Floating stat pills ── */
  .t-stat {
    position: absolute;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1px;
    background: var(--surface);
    border: 1px solid var(--border);
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.09), 0 8px 24px rgba(0,0,0,0.12);
    backdrop-filter: blur(12px);
    border-radius: 12px;
    padding: 10px 18px;
    opacity: 0;
    animation: fadeIn 0.5s ease forwards;
  }
  .t-stat-a {
    top: -18px; right: -18px;
    animation-delay: 3.6s;
    animation: fadeIn 0.5s ease 3.6s forwards, float2 5s ease-in-out 4.1s infinite;
  }
  .t-stat-b {
    bottom: -18px; left: -18px;
    animation: fadeIn 0.5s ease 3.9s forwards, float3 6s ease-in-out 4.4s infinite;
  }
  .t-num {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--text);
    line-height: 1;
    font-family: "Courier New", monospace;
    letter-spacing: -0.03em;
  }
  .t-lbl {
    font-size: 9.5px;
    color: var(--text-3);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-top: 2px;
  }
</style>
